{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@/components/*": [
                "./src/components/*"
            ],
            "@/hooks/*": [
                "./src/hooks/*"
            ],
            "@/utils/*": [
                "./src/utils/*"
            ],
            "@/types/*": [
                "./src/types/*"
            ],
            "@/stores/*": [
                "./src/stores/*"
            ],
            "@/contexts/*": [
                "./src/contexts/*"
            ],
            "@/lib/*": [
                "./src/lib/*"
            ],
            "@/actions/*": [
                "./src/actions/*"
            ]
        },
        "allowJs": true,
        "esModuleInterop": true
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}